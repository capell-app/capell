            identifier: return.type
            count: 1
            path: ../packages/core/src/Console/Commands/CloudBootstrapCommand.php

        # Current level-3 debt kept out of the deleted baseline; fix these into code over time.
        -
            message: '#^Method Capell\\Admin\\Filament\\Components\\Forms\\Page\\CreatePageSchema\:\:getParentPageSelect\(\) should return Capell\\Admin\\Filament\\Components\\Forms\\Page\\ParentSelect but returns Capell\\Admin\\Filament\\Components\\Forms\\PageRelationSelect\.$#'
            identifier: return.type
            count: 1
