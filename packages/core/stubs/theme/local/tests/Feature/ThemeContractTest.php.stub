<?php

declare(strict_types=1);

use Capell\Core\Testing\ExtensionTestHarness;

it('has a valid Capell theme manifest', function (): void {
    ExtensionTestHarness::forPath(dirname(__DIR__, 2))
        ->assertManifestValid()
        ->assertThemeManifest('{{ themeKey }}')
        ->assertThemeUsesSafeAssetUrls();
});

it('renders the generated theme page', function (): void {
    $html = view('{{ slug }}::page', ['content' => '<p>Generated theme content</p>'])->render();

    expect($html)
        ->toContain('{{ themeKey }}-page')
        ->toContain('<p>Generated theme content</p>');
});
